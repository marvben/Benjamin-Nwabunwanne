<nav class="custom-nav">
    <div class="cutstom-nav-wrapper for-desktop">
        <div class="site-logo"><img src="{{section.settings.site_logo}}" width="300px" height="auto"></div>
        <div class="site-notice">{{ section.settings.nav_notice }}</div>
        <a class="nav-button" href="{{ section.settings.button_icon }}">{{ section.settings.button_text }} <img src="{{section.settings.button_icon}}" width="50px" height="auto"></a>
    </div> 

    <div class="cutstom-nav-wrapper for-mobile">
        <div class="nav-top">
            <img class="dropdwon-button close" src="https://cdn.shopify.com/s/files/1/0988/0495/7495/files/Group_1000008115.png?v=1777917810" height="auto" width="18px">
            <img class="dropdwon-button open" src="https://cdn.shopify.com/s/files/1/0988/0495/7495/files/Group_1000008115_1.png?v=1777917812" height="auto" width="18px">
            <div class="site-logo"><img src="{{section.settings.site_logo}}" width="300px" height="auto"></div>
        </div>
        <div class="nav-dropdown">dropdown</div>
    </div>
</nav>


<style>
.custom-nav{
    display:flex;
    align-items:center;
    justify-content:center;
    width:100%;
    background:rgba(245, 245, 245, 1);
    font-family: 'Jost';
    font-weight: 400;
    font-size: 16px;
    text-align: center;
}

.for-desktop{
display:none !important}

 .cutstom-nav-wrapper,
 .cutstom-nav-wrapper.for-mobile .nav-top{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:10px 50px;
    width:100%;
    max-width:1440px;
}
.cutstom-nav-wrapper.for-mobile .nav-top{
    justify-content:center;
}

.dropdwon-button{
    margin-right:auto
}

a.nav-button{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    width:210px;
    height:50px;
    border:1px solid #000;
    color:{{section.settings.button_text_color}};
    background:{{ section.settings.button_background_color }};
    line-height: 20.48px;
    letter-spacing: 0px;
    text-transform: uppercase;
    text-decoration:none
}

.site-notice{
line-height: 13.42px;
letter-spacing: 0px;

}
</style>


{% schema %}
{
  "name": "Custom header",
  "settings": [
    {
      "type": "image_picker",
      "id": "site_logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "choose gift"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button Background",
      "default": "rgba(255, 245, 68, 1)"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#000"
    },
    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Button Icon"
    },
    {
      "type": "text",
      "id": "nav_notice",
      "label": "Nav Notive",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "color",
      "id": "nav_notice_text_color",
      "label": "Nav Notice Text Color",
      "default": "#000"
    }
  ],
  "presets": [
    {
      "name": "custom header"
    }
  ]
}
{% endschema %}