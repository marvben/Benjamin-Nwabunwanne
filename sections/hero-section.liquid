{{ 'section-hero-section.css' | asset_url | stylesheet_tag }}

<section
  class="hero-section"
  style="
    background-image:url({{ section.settings.background_image }});
    background-size:{{ section.settings.background_size }};
    background-position:{{ section.settings.background_position }};
    min-height:{{ section.settings.hero_text_content__min_height }}vh;
    align-items:{{ section.settings['align-items'] }};
    justify-content:{{ section.settings['justify-content'] }};
  "
>
  <div
    class="hero-text-content"
    style="
      width:100%;
      max-width:{{ section.settings.hero_text_content__max_width }}px;
      color:{{ section.settings.text_color }};
    "
  >
    <h1 class="hero-heading" style="color:{{ section.settings.heading_color }}">{{ section.settings.heading }}</h1>
    <p class="hero-subheading" style="color:{{ section.settings.subheading_color }}">
      {{ section.settings.subheading }}
    </p>
    {% if section.settings.button_text != blank %}
      <a
        href="{{ section.settings.button_link }}"
        class="hero-button"
        style="background-color:{{ section.settings.button_background_color }}; color:{{ section.settings.button_text_color }};"
      >
        {{- section.settings.button_text }}
        {% if section.settings.button_icon != blank %}
          <img
            class="hero-button-icon"
            src="{{ section.settings.button_icon | image_url : width: 24 }}"
            width="24"
            height="auto"
            alt="Button Icon"
          >
        {% endif %}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "range",
      "id": "hero_text_content__min_height",
      "label": "Hero Text Content Min Height",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "vh",
      "default": 50
    },
    {
      "type": "range",
      "id": "hero_text_content__max_width",
      "label": "Hero Text Content Max Width",
      "min": 100,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "default": 600
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background Size",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background Position",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "top",
          "label": "Top"
        },
        { "value": "bottom", "label": "Bottom" },
        { "value": "top left", "label": "Top Left" },
        { "value": "top right", "label": "Top Right" },
        { "value": "center left", "label": "Center Left" },
        { "value": "center right", "label": "Center Right" },
        { "value": "bottom left", "label": "Bottom Left" },
        { "value": "bottom right", "label": "Bottom Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "align-items",
      "label": "Align Items",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "justify-content",
      "label": "Justify Content",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#000000" },

    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our latest collection"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#000000"
    },

    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Button Icon (optional)"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
