<section
  class="hero-section"
  style="
    background-image:url({{ section.settings.background_image }})
    background-size:{{ section.settings.background_size }};
    background-position:{{ section.settings.background_position }};
    height:{{ section.settings.hero_text_content__height }}

    align-items:{{section.settings.align-items}};
    justify-content:{{section.settings.justify-content}};
  "
>
  <div
    class="hero-text-content "
    style="
      width:'100%';
      max-width:{{ section.settings.hero_text_content__max_width }};
    "
  >
    <h1 class="hero-heading">{{ section.settings.heading }}</h1>
    <p class="hero-subheading">{{ section.settings.subheading }}</p>
    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="hero-button">
        {{- section.settings.button_text }}
        {% if section.settings.button_icon != blank %}
          <img
            class="hero-button-icon"
            src="{{ section.settings.button_icon | image_url : width: 24 }}"
            width="24"
            height="auto"
            alt="Button Icon"
          >
        {% endif %}
      </a>
    {% endif %}
  </div>
</section>

<style>
  .hero-section {
    display: flex;
    flex-direction: column;
    position: relative;
    color: #000;
    text-align: left;
  }

  .hero-text-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 40px;
    font-family: 'Jost';
  }
  .hero-text-content h1,
  .hero-text-content p,
  .hero-text-content a {
    margin: 0;
    padding: 0;
    color: inherit;
  }

  .hero-heading {
    font-weight: 500;
    font-size: 70px;
    line-height: 1;
    letter-spacing: 0px;
  }

  .hero-subheading {
    font-weight: 400;
    font-size: 20px;
    line-height: 140%;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    background-color: #000;
    text-decoration: none;
    border-radius: 0;
    font-size: 16px;
    font-weight: bold;
    font-weight: 400;
    line-height: 20.48px;
    letter-spacing: 0px;
    text-align: center;
    text-transform: uppercase;
  }
  .hero-button-icon {
    max-width: 24px;
    height: auto;
    width: 100%;
  }
</style>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background Size",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background Position",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "top",
          "label": "Top"
        },
        { "value": "bottom", "label": "Bottom" },
        { "value": "top left", "label": "Top Left" },
        { "value": "top right", "label": "Top Right" },
        { "value": "center left", "label": "Center Left" },
        { "value": "center right", "label": "Center Right" },
        { "value": "bottom left", "label": "Bottom Left" },
        { "value": "bottom right", "label": "Bottom Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "align-items",
      "label": "Align Items",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "justify-content",
      "label": "Justify Content",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our latest collection"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Button Icon (optional)"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
