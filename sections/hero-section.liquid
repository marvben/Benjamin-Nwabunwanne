{%- comment -%} Hero Section {%- endcomment -%}

{{ 'section-hero-section.css' | asset_url | stylesheet_tag }}

<section
  class="hero-section"
  style="
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
    {% endif %}
    background-size: {{ section.settings.background_size }};
    background-position: {{ section.settings.background_position }};
    background-repeat: no-repeat;
    min-height: {{ section.settings.hero_height_desktop }}vh;
    display: flex;
    align-items: {{ section.settings.align_items }};
    justify-content: {{ section.settings.justify_content }};
    position: relative;
  "
>
  <!-- Overlay -->
  <div
    class="hero-overlay"
    style="      background: rgba(0,0,0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});"
  ></div>

  <!-- Content -->
  <div
    class="hero-text-content"
    style="
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: {{ section.settings.hero_text_content__max_width }}px;
      color: {{ section.settings.text_color }};
      padding: 40px;
    "
  >
    <h1 class="hero-heading" style="color: {{ section.settings.heading_color }}">
      {{ section.settings.heading }}
    </h1>

    <p class="hero-subheading" style="color: {{ section.settings.subheading_color }}">
      {{ section.settings.subheading }}
    </p>

    {% if section.settings.button_text != blank %}
      <a
        href="{{ section.settings.button_link }}"
        class="hero-button"
        style="
          background-color: {{ section.settings.button_background_color }};
          color: {{ section.settings.button_text_color }};
        "
      >
        {{ section.settings.button_text }}

        {% if section.settings.button_icon != blank %}
          <img
            src="{{ section.settings.button_icon | image_url: width: 24 }}"
            width="24"
            height="24"
            alt="Button Icon"
          >
        {% endif %}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background Size",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Desktop Background Position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Center Top" },
        { "value": "center bottom", "label": "Center Bottom" },
        { "value": "left top", "label": "Left Top" },
        { "value": "left center", "label": "Left Center" },
        { "value": "left bottom", "label": "Left Bottom" },
        { "value": "right top", "label": "Right Top" },
        { "value": "right center", "label": "Right Center" },
        { "value": "right bottom", "label": "Right Bottom" }
      ],
      "default": "center center"
    },
    {
      "type": "select",
      "id": "background_position_mobile",
      "label": "Mobile Background Position",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "label": "Hero Height (Desktop)",
      "min": 40,
      "max": 100,
      "step": 10,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Hero Height (Mobile)",
      "min": 30,
      "max": 100,
      "step": 10,
      "unit": "vh",
      "default": 60
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "hero_text_content__max_width",
      "label": "Content Width",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "select",
      "id": "align_items",
      "label": "Vertical Alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "justify_content",
      "label": "Horizontal Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#000" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Welcome to Our Store" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "inherit" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Discover our latest collection" },
    { "type": "color", "id": "subheading_color", "label": "Subheading Color", "default": "inherit" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "color", "id": "button_background_color", "label": "Button Background", "default": "#000000" },
    { "type": "color", "id": "button_text_color", "label": "Button Text Color", "default": "#fff" },
    { "type": "image_picker", "id": "button_icon", "label": "Button Icon" }
  ],
  "presets": [{ "name": "Hero Section" }]
}
{% endschema %}
