{%- comment -%} Hero Section {%- endcomment -%}

{{ 'section-hero-section.css' | asset_url | stylesheet_tag }}

<div class="hero-section">
  <!-- Overlay -->
  <div class="hero-overlay"></div>

  <!-- Content -->
  <div class="hero-text-content">
    <h1 class="hero-heading">
      {{ section.settings.heading }}
    </h1>

    <p class="hero-subheading">
      {{ section.settings.subheading }}
    </p>

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="hero-button">
        {{ section.settings.button_text }}

        {% if section.settings.button_icon != blank %}
          <img
            class="hero-button-icon"
            src="{{ section.settings.button_icon | image_url: width: 24 }}"
            width="24"
            height="24"
            alt="Button Icon"
          >
        {% endif %}
      </a>
    {% endif %}
  </div>
</div>

{% if section.settings.hero_notice != blank %}
  <div class="hero-notice">
    {{ section.settings.hero_notice }}
  </div>
{% endif %}

<style>
  /* =========================
     DESKTOP STYLES
  ========================= */
  .hero-section {
    align-items: {{ section.settings.align_items }};
    justify-content: {{ section.settings.justify_content }};
    min-height: {{ section.settings.hero_height_desktop }}vh;
    {% if section.settings.desktop_background_image != blank %}
      background-image: url('{{ section.settings.desktop_background_image | image_url: width: 2000 }}');
    {% endif %}
    background-size: {{ section.settings.background_size }};
    background-position: {{ section.settings.background_position }};
  }

  .hero-overlay {
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
  }

  .hero-text-content {
    max-width: {{ section.settings.hero_text_content__max_width }}px;
    min-height:{{ section.settings.desktop_hero_text_min__height }}px;
    color: {{ section.settings.text_color }};
  }

  .hero-heading {
    color: {{ section.settings.heading_color }};
  }

  .hero-subheading {
    color: {{ section.settings.subheading_color }};
  }

  .hero-button {
    background-color: {{ section.settings.button_background_color }};
    color: {{ section.settings.button_text_color }};

  }

  .hero-notice {
    background: {{ section.settings.hero_notice_background }};
    color: {{ section.settings.hero_notice_text_color }};
    padding: {{ section.settings.hero_notice_padding }};
    text-align: {{ section.settings.hero_notice_text_align }};
  }

  /* =========================
     MOBILE OPTIMIZATION
  ========================= */
  @media (max-width: 749px) {
    .hero-section {
        {% if section.settings.mobile_background_image != blank %}
      background-image: url('{{ section.settings.mobile_background_image | image_url: width: 2000 }}');
        background-position: {{ section.settings.background_position_mobile }};
      {% endif %}
      min-height: {{ section.settings.hero_height_mobile }}vh;
    }

    .hero-text-content {
      min-height:{{ section.settings.mobile_hero_text_min__height }}px;
    }


  }
</style>
{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_background_image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_background_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background Size",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Desktop Background Position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top Center" },
        { "value": "center bottom", "label": "Bottom Center" },
        { "value": "left center", "label": "Left Center" },
        { "value": "left top", "label": "Top Left" },
        { "value": "left bottom", "label": "Bottom Left" },
        { "value": "right center", "label": "Right Center" },
        { "value": "right top", "label": "Top Right" },
        { "value": "right bottom", "label": "Bottom Right" }
      ],
      "default": "center center"
    },
    {
      "type": "select",
      "id": "background_position_mobile",
      "label": "Mobile Background Position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top Center" },
        { "value": "center bottom", "label": "Bottom Center" },
        { "value": "left center", "label": "Left Center" },
        { "value": "left top", "label": "Top Left" },
        { "value": "left bottom", "label": "Bottom Left" },
        { "value": "right center", "label": "Right Center" },
        { "value": "right top", "label": "Top Right" },
        { "value": "right bottom", "label": "Bottom Right" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "label": "Hero Height (Desktop)",
      "min": 40,
      "max": 100,
      "step": 10,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Hero Height (Mobile)",
      "min": 30,
      "max": 100,
      "step": 10,
      "unit": "vh",
      "default": 60
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "hero_text_content__max_width",
      "label": "Content Width",
      "min": 300,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "desktop_hero_text_min__height",
      "label": "Desktop Content Min Height",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "mobile_hero_text_min__height",
      "label": "Mobile Content Min Height",
      "min": 150,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 250
    },
    {
      "type": "select",
      "id": "align_items",
      "label": "Vertical Alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "justify_content",
      "label": "Horizontal Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our latest collection"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Button Icon"
    },
    {
      "type": "text",
      "id": "hero_notice",
      "label": "Hero Notice Text",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    },
    {
      "type": "color",
      "id": "hero_notice_background",
      "label": "Hero Notice Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "hero_notice_text_color",
      "label": "Hero Notice Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "hero_notice_padding",
      "label": "Hero Notice Padding",
      "default": "10px 20px"
    },
    {
      "type": "select",
      "id": "hero_notice_text_align",
      "label": "Hero Notice Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
