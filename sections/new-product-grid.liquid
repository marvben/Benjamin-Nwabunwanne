{{ 'new-product-grid-section.css' | asset_url | stylesheet_tag }}


{% if section.settings.collection != blank %}
  <div class="new-product-grid-section">
    {% if section.settings.section_heading != blank %}
      <h2 class="new-product-grid-heading">{{ section.settings.section_heading }}</h2>
    {% endif %}
    <div
      class="new-products-grid-wrapper"
      style="--columns-desktop: {{ section.settings.columns_desktop }}; --columns-mobile: {{ section.settings.columns_mobile }};"
    >
      {% assign products = section.settings.collection.products %}
      {% if products.size > 0 %}
        {% for product in products limit: section.settings.products_to_show %}
          {% if product.featured_image != blank %}
            <div class="new-product-grid-item">
              {{
                product.featured_image
                | image_url: width: 500
                | image_tag:
                  alt: product.title,
                  loading: 'lazy',
                  width: '100%',
                  height: '100%',
                  class: 'new-product-image'
              }}
              <i class="product-button" data-product-link="{{ product.url }}"></i>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <p class="no-products-message">No products found in this collection.</p>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "New Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "New Arrivals"
    },
    { "type": "collection", "id": "collection", "label": "Select Collection" },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of Products to Show",
      "default": 6,
      "min": 3,
      "max": 24
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on Desktop",
      "options": [
        { "value": "2", "label": "Two" },
        { "value": "3", "label": "Three" },
        { "value": "4", "label": "Four" },
        { "value": "5", "label": "Five" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on Mobile",
      "options": [
        { "value": "1", "label": "One" },
        { "value": "2", "label": "Two" }
      ],
      "default": "1"
    }
  ],
  "presets": [
    {
      "name": "New Product Grid",
      "category": "Products"
    }
  ]
}
{% endschema %}

{% javascript %}
  const quickViewButtons = document.querySelectorAll('.product-button');
  const quickViewPopup = document.querySelector('.product-quick-view__popup');
  const quickViewPopupOverlay  = document.querySelector('.product-quick-view__popup-overlay');
  const quickViewContainer = document.querySelector('.product-quick-view__container');
  const quickViewCloseButton = document.querySelector('.product-quick-view__close-button')

  quickViewButtons.forEach(quickViewButton => {
    quickViewButton.addEventListener('click', ()=>{
      quickViewPopup.classList.add('active');
      console.log(quickViewButton.dataset)
      // quickViewPopupOverlay.classList.add('active');
      // quickViewContainer.classList.add('active')
    })
  });

  quickViewCloseButton.addEventListener('click', ()=>{
    quickViewPopup.classList.remove('active');
  });

  quickViewPopupOverlay.addEventListener('click', ()=>{
    quickViewPopup.classList.remove('active');
  })
  
{% endjavascript %}


