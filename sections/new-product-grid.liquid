{{ 'new-product-grid-section.css' | asset_url | stylesheet_tag }}
{% if section.settings.collection != blank %}
  <div class="new-product-grid-section">
    {% if section.settings.section_heading != blank %}
      <h2 class="new-product-grid-heading">{{ section.settings.section_heading }}</h2>
    {% endif %}
    <div
      class="new-products-grid-wrapper"
      style="--columns-desktop: {{ section.settings.columns_desktop }}; --columns-mobile: {{ section.settings.columns_mobile }};"
    >
      {% assign products = section.settings.collection.products %}
      {% if products.size > 0 %}
        {% for product in products limit: section.settings.products_to_show %}
          {% if product.featured_image != blank %}
            <div class="new-product-grid-item">
              {{
                product.featured_image
                | image_url: width: 500
                | image_tag:
                  alt: product.title,
                  loading: 'lazy',
                  width: '100%',
                  height: '100%',
                  class: 'new-product-image'
              }}
              <i class="product-button"></i>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <p class="no-products-message">No products found in this collection.</p>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "New Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "New Arrivals"
    },
    { "type": "collection", "id": "collection", "label": "Select Collection" },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of Products to Show",
      "default": 6,
      "min": 3,
      "max": 24
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on Desktop",
      "options": [
        { "value": "2", "label": "Two" },
        { "value": "3", "label": "Three" },
        { "value": "4", "label": "Four" },
        { "value": "5", "label": "Five" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on Mobile",
      "options": [
        { "value": "1", "label": "One" },
        { "value": "2", "label": "Two" }
      ],
      "default": "1"
    }
  ],
  "presets": [
    {
      "name": "New Product Grid",
      "category": "Products"
    }
  ]
}
{% endschema %}


{% comment %} Temp popout layout {% endcomment %}

<div class="product-quick-view__container">
  <div class="product-quick-view__content">
    <div class="product-quick-view__content-image-wrapper">
    <img src="https://benjamin-nwabunwanne-48-teststore.myshopify.com/cdn/shop/files/womens-red-t-shirt_925x_5cbc9e3a-3e59-4707-aa55-d1483ba0349a.jpg?v=1777072736&width=352" class="product-quick-view__content-image" 
    height="100%" width="100%">
    </div>
    <div class="product-quick-view__content-text-wrapper">
      <h4 class="product-quick-view__content-text-title">Orange Wide Leg</h4>
      <span class="product-quick-view__content-text-price">980,00€</span>
      <p class="product-quick-view__content-text-desc">This one-piece swimsuit is crafted from jersey featuring an allover micro Monogram motif in relief.</p>
    </div>
  </div>
  <form id="product-quick-view-form" class="product-quick-view__form">
    <div class="product-quick-view__colors">
      <span>Color</span>
      <div class="product-quick-view__color-options">
        <label class="product-quick-view__color-option">White
          <input type="radio" value="white">
        </label>
        <label class="product-quick-view__color-option">Black
          <input type="radio" value="white">
        </label>
      </div>
    </div>

    <div class="product-quick-view__sizes">
      <span>Size</span>
      <select class="product-quick-view__size-options">
        <option class="product-quick-view__size-option" value="L" >White</option>
        <option class="product-quick-view__size-option" value="L" >White</option>
        <option class="product-quick-view__size-option" value="L" >White</option>
        <option class="product-quick-view__size-option" value="L" >White</option>
      </select>
    </div>

    <div class="product-quick-view__button-wrapper">
      <input class="product-quick-view__button" type="submit" value="Add to cart">
      <div class="product-quick-view__button-icon" >
        <img src="https://cdn.shopify.com/s/files/1/0988/0495/7495/files/Line_15.png?v=1777474777" height="auto" width="100%">
      </div>
    </div>
  </form>
  <span class="product-quick-view__close-button"></span>
</div> 

<style>
.product-quick-view__container{
  background:#fff;
  width:100%;
  height:70vh;
  max-width:310px;
  max-height:450px;
  overflow:auto;
  padding:20px;
  position:relative
}

.product-quick-view__content{
  display:flex;
  flex-direction:row;
  gap:10px;
}

.product-quick-view__content-image-wrapper{
  display:flex;
  flex-grow:1;
  height:140px;
  width:120px;
  overflow:hidden;
}
.product-quick-view__content-image-wrapper img{
  width:100%;
  height:100%;
  object-fit:cover
}

.product-quick-view__content-text-wrapper{
  max-width:150px;
  text-align:left;
  display:flex;
  flex-direction:column;
  justify-content: flex-end;
  align-items: flex-start;
  gap: 20px;
  flex-shrink:1;
  font-weight: 300;
  font-family: 'jost';
}

.product-quick-view__content-text-title,
.product-quick-view__content-text-price,
.product-quick-view__content-text-desc{
  margin:0;
}

.product-quick-view__content-text-title{
  font-size:16px;
  line-height: 1.2;
}
.product-quick-view__content-text-price{
font-family: Lustria;
font-weight: 400;
font-size: 16px;
line-height: 1.2;
}
.product-quick-view__content-text-desc{
font-size: 14px;
line-height: 1;
letter-spacing: -1%;
}

.product-quick-view__button-wrapper{
background:#000;
color:#fff;
display:flex;
flex-direction:row;
align-items:center;
justify-content:center;
gap:20px
}
.product-quick-view__button-icon{
  width:30px;
  height:auto;
  overflow:hidden
}
.product-quick-view__button-icon img{
width:100%;
}

.product-quick-view__close-button{
  position:absolute;
  top:10px;
  right:10px;
  display:inline-block;
  width:12px;
  height:12px;
  background:red;
  z-index:100
}

.product-quick-view__close-button::before{
  content:"";
  position:absolute;
  width:100%;
  height:2px;
  background:#000;
  top:50%;
  transform:translatey(-50%)
}

</style>